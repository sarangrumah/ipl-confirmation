# =============================================================
# IPL Confirmation — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ipl_db"

# --- Google Drive (Service Account) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project-id.iam.gserviceaccount.com"
# Paste the full private key including header/footer lines.
# Replace literal \n with actual newlines, OR keep \n and let driveService.js handle it.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# --- Dashboard Basic Auth ---
# Both values are required. The server will refuse to start if either is missing.
# Use a strong, unique password — this is the only gate to the admin dashboard.
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="change_this_to_a_strong_password"

# --- App ---
PORT=3000
NODE_ENV=development
