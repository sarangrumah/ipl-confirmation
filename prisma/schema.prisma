generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Payment {
  id             Int           @id @default(autoincrement())
  sender_number  String
  block_number   String
  payment_month  String
  amount         Decimal       @db.Decimal(12, 2)
  evidence_url   String        // https://drive.google.com/uc?export=view&id={fileId}
  status         PaymentStatus @default(PENDING)
  created_at     DateTime      @default(now())

  @@index([block_number])
  @@index([status])
  @@index([created_at])
}
